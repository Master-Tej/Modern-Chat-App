NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/modern_chat"
JWT_ACCESS_SECRET="change-this-to-a-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-random-secret-at-least-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
CLIENT_URL="http://localhost:3000"
